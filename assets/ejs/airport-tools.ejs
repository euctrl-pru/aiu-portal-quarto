```{=html}

<div class="list grid" style="column-gap: 24px; row-gap: 36px;">

    <% for (const item of items) { %>

    <div class="g-col-12 g-col-sm-6 g-col-lg-3"
         <%= metadataAttrs(item) %>>

        <div class="card rounded-3 h-100 overflow-hidden">

            <a href="<%- item.href %>">
                <img src="<%- item.image %>"
                     alt="<%- item.title %>"
                     class="card-img-top"
                     loading="lazy">
            </a>

            <div class="card-body d-flex flex-column text-start">

                <a href="<%- item.href %>" class="text-decoration-none">
                    <h5 class="card-title listing-title mb-2">
                        <%= item.title %>
                    </h5>
                </a>

                <p class="card-text mb-3"
                   style="font-size: 0.9rem; line-height: 1.35;">
                    <%= item.description %>
                </p>

                <div class="mt-auto">
                    <span class="badge <%- item.badgeclass %>">
                        <%= item.badge %>
                    </span>
                </div>

            </div>

        </div>

    </div>

    <% } %>

</div>


```